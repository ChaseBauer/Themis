# Themis environment configuration
# Copy to .env and fill in required values before running docker compose up.

# Security, required
# A long, random string used to sign JWT tokens.
# Generate one with: openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-secret

# Database
# Credentials for the bundled PostgreSQL container.
# If POSTGRES_EXTERNAL_URL is set, the bundled Postgres container is still
# started but the backend connects to the external URL instead.  To disable
# the bundled container entirely, comment out the postgres service in
# docker-compose.yml and set DATABASE_URL directly.
POSTGRES_USER=themis
POSTGRES_PASSWORD=themis
POSTGRES_DB=themis
# DATABASE_URL=postgresql://themis:themis@postgres:5432/themis   # set automatically

# External database, optional. Overrides the bundled container.
# DATABASE_URL=postgresql://user:pass@db-host:5432/themis

# Ports
# Port the frontend (nginx) listens on.  Change to 8080 if 80 is in use.
HTTP_PORT=80
# Exposed backend port (useful for local dev; reverse-proxied by nginx in prod).
BACKEND_PORT=8080

# TLS / HTTPS
# Used by docker-compose.https.yml.  Leave empty if terminating TLS upstream.
# DOMAIN=themis.example.com
# LETSENCRYPT_EMAIL=admin@example.com

# Application behaviour
# Maximum number of golden config versions to retain per device (oldest pruned).
MAX_GOLDEN_CONFIGS=10

# Logging
# Rust tracing filter.  Options: error | warn | info | debug | trace
# Use 'themis_backend=debug,tower_http=debug' for verbose request logging.
RUST_LOG=themis_backend=info

# Image registry
# Override when pulling pre-built images from a private registry or GHCR.
# Used by docker-compose.prod.yml.
# IMAGE_REGISTRY=ghcr.io/your-org
# IMAGE_TAG=latest
